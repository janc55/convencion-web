---

<footer class="bg-[#00132f] border-t border-white/5 py-12">
  <div
    class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-3 gap-12 items-start animate-on-scroll from-bottom"
  >
    <div class="space-y-6">
      <span class="font-['Newsreader'] text-xl text-[#eec200]"
        >Club de Leones de Bolivia</span
      >
      <p class="text-[#aac7ff]/70 text-sm leading-relaxed">
        "Nosotros Servimos". Institución internacional dedicada al servicio
        humanitario con más de 100 años de historia global.
      </p>
      <div class="flex gap-4">
        <a class="text-secondary hover:text-primary transition-colors" href="#"
          ><span class="material-symbols-outlined">social_leaderboard</span></a
        >
        <a class="text-secondary hover:text-primary transition-colors" href="#"
          ><span class="material-symbols-outlined">chat</span></a
        >
        <a class="text-secondary hover:text-primary transition-colors" href="#"
          ><span class="material-symbols-outlined">camera_enhance</span></a
        >
      </div>
    </div>

    <div class="grid grid-cols-2 gap-8">
      <div class="space-y-4">
        <h5 class="text-[#eec200] font-bold text-xs uppercase tracking-widest">
          Convención
        </h5>
        <ul
          class="space-y-2 text-[#aac7ff]/70 text-sm font-['Plus_Jakarta_Sans'] uppercase tracking-widest"
        >
          <li>
            <a class="hover:text-[#eec200] transition-colors" href="#">Agenda</a
            >
          </li>
          <li>
            <a class="hover:text-[#eec200] transition-colors" href="#"
              >Hoteles</a
            >
          </li>
          <li>
            <a class="hover:text-[#eec200] transition-colors" href="#"
              >Turismo</a
            >
          </li>
        </ul>
      </div>
      <div class="space-y-4">
        <h5 class="text-[#eec200] font-bold text-xs uppercase tracking-widest">
          Ayuda
        </h5>
        <ul
          class="space-y-2 text-[#aac7ff]/70 text-sm font-['Plus_Jakarta_Sans'] uppercase tracking-widest"
        >
          <li>
            <a class="hover:text-[#eec200] transition-colors" href="#"
              >Registro</a
            >
          </li>
          <li>
            <a class="hover:text-[#eec200] transition-colors" href="#"
              >Contacto</a
            >
          </li>
          <li>
            <a class="hover:text-[#eec200] transition-colors" href="#"
              >Ubicación</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div class="text-right space-y-4">
      <div
        class="bg-surface-container p-6 rounded-lg inline-block text-left border border-primary/10"
      >
        <p
          class="text-xs uppercase tracking-widest text-primary font-bold mb-2"
        >
          Contacto Directo
        </p>
        <p class="text-on-surface">+591 65433511</p>
        <p class="text-on-surface">secretaria@clubdeleonesbolivia.lat</p>
      </div>
      <p class="text-xs text-[#aac7ff]/40 pt-4 uppercase tracking-widest">
        Club de Leones de Bolivia · Distrito B-1 y B-2<br />
        © 2026 Todos los derechos reservados · Desarrollado por NettiDev
      </p>
    </div>
  </div>
</footer>
