---
---

<header class="fixed top-0 w-full z-50 bg-[#00132f]/80 backdrop-blur-lg shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
  <nav class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto relative">
    <div class="flex items-center gap-4">
      <img src="/images/logo-leones.png" alt="Logo Leones" class="w-10 h-10 object-contain drop-shadow-[0_0_10px_rgba(238,194,0,0.3)]" />
      <span class="font-['Newsreader'] italic text-2xl text-[#eec200]">Lions Bolivia</span>
    </div>
    
    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-8 font-['Newsreader'] tracking-tight font-light">
      <a class="text-[#eec200] border-b-2 border-[#eec200] pb-1" href="#hero">Inicio</a>
      <a class="text-[#aac7ff] hover:text-[#eec200] transition-colors" href="#programa">Agenda</a>
      <a class="text-[#aac7ff] hover:text-[#eec200] transition-colors" href="#hoteles">Hoteles</a>
      <a class="text-[#aac7ff] hover:text-[#eec200] transition-colors" href="#turismo">Turismo</a>
      <a class="text-[#aac7ff] hover:text-[#eec200] transition-colors" href="#registro">Registro</a>
    </div>

    <!-- Actions & Mobile Toggle -->
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[#eec200] cursor-pointer hover:bg-white/5 p-2 rounded-full transition-all">account_balance_wallet</span>
      <button id="mobile-menu-btn" class="lg:hidden material-symbols-outlined text-[#eec200] cursor-pointer hover:bg-white/5 p-2 rounded-full transition-all" aria-label="Abrir menú">
        menu
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 w-full bg-[#001b3e] flex-col border-t border-white/5 shadow-2xl pb-4 pt-2 px-6">
    <a class="mobile-link text-[#eec200] font-['Newsreader'] text-lg py-3 border-b border-white/5" href="#hero">Inicio</a>
    <a class="mobile-link text-[#aac7ff] font-['Newsreader'] text-lg py-3 border-b border-white/5 hover:text-[#eec200]" href="#programa">Agenda</a>
    <a class="mobile-link text-[#aac7ff] font-['Newsreader'] text-lg py-3 border-b border-white/5 hover:text-[#eec200]" href="#hoteles">Hoteles</a>
    <a class="mobile-link text-[#aac7ff] font-['Newsreader'] text-lg py-3 border-b border-white/5 hover:text-[#eec200]" href="#turismo">Turismo</a>
    <a class="mobile-link text-[#aac7ff] font-['Newsreader'] text-lg py-3 hover:text-[#eec200]" href="#registro">Registro</a>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      // Toggle hidden and flex
      mobileMenu.classList.toggle('hidden');
      mobileMenu.classList.toggle('flex');
    });

    // Close menu when a link is clicked
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        mobileMenu.classList.remove('flex');
      });
    });
  }
</script>
