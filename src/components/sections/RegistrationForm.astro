---

---

<section class="py-24 bg-[#0c3569] relative" id="registro">
  <div class="absolute inset-0 hex-pattern opacity-10"></div>
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div
      class="bg-surface-container-high p-8 md:p-12 rounded-2xl shadow-2xl border border-primary/20 animate-on-scroll scale-up"
    >
      <h2 class="font-headline text-4xl text-center text-primary mb-4">
        Registro de Participantes
      </h2>
      <p class="text-center text-secondary mb-6">
        Complete el formulario para confirmar su asistencia a la convención.
      </p>

      <div
        id="registration-countdown"
        class="text-center mb-8 py-4 px-6 bg-primary/10 border border-primary/30 rounded-lg"
      >
        <p class="text-lg text-on-surface">
          <span class="font-bold text-primary text-2xl" id="days-remaining"
            >--</span
          >
          <span class="text-on-surface"> días para el cierre de registro</span>
        </p>
        <p class="text-sm text-secondary mt-1">
          Fecha límite: 20 de abril de 2026
        </p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <form id="registration-form" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Nombres</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="Ej. Juan"
                  type="text"
                  name="first_name"
                  required
                />
              </div>
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Apellidos</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="Ej. Pérez"
                  type="text"
                  name="last_name"
                  required
                />
              </div>
            </div>
            <div class="grid md:grid-cols-1 gap-6">
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Club de Leones</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="Nombre de su Club"
                  type="text"
                  name="club"
                />
              </div>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Distrito</label
                >
                <select
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  name="district"
                >
                  <option class="bg-surface" value="Distrito S1">Distrito S1</option>
                  <option class="bg-surface" value="Distrito S2">Distrito S2</option>
                  <option class="bg-surface" value="Otro">Otro</option>
                </select>
              </div>
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >País</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  type="text"
                  value="Bolivia"
                  name="country"
                />
              </div>
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Cartera</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="Ej. Presidente"
                  type="text"
                  name="role_title"
                />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Correo Electrónico</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="usuario@correo.com"
                  type="email"
                  name="email"
                  required
                />
              </div>
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Teléfono / WhatsApp</label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="+591 ..."
                  type="tel"
                  name="phone"
                />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Tipo de Participante</label
                >
                <div class="flex gap-8 pt-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      class="text-primary focus:ring-primary bg-transparent border-primary/40"
                      name="participant_type"
                      type="radio"
                      value="delegado"
                      required
                    />
                    <span class="text-sm">Delegado</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input
                      class="text-primary focus:ring-primary bg-transparent border-primary/40"
                      name="participant_type"
                      type="radio"
                      value="invitado"
                    />
                    <span class="text-sm">Invitado</span>
                  </label>
                </div>
              </div>
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Nro. de León <span class="text-secondary font-normal"
                    >(Opcional)</span
                  ></label
                >
                <input
                  class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                  placeholder="Ej. 123456"
                  type="text"
                  name="lion_number"
                />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Foto para Credencial</label
                >
                <div
                  class="border-2 border-dashed border-outline-variant rounded-lg p-4 text-center hover:border-primary transition-colors cursor-pointer"
                  id="photo-dropzone"
                >
                  <input
                    class="hidden"
                    id="photo-input"
                    name="photo"
                    type="file"
                    accept="image/*"
                  />
                  <div id="photo-preview-container" class="hidden mb-3">
                    <img
                      id="photo-preview"
                      class="w-32 h-32 object-cover rounded-lg mx-auto hidden"
                      alt="Preview"
                    />
                  </div>
                  <div id="photo-placeholder">
                    <svg
                      class="w-8 h-8 mx-auto text-secondary mb-2"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      ></path>
                    </svg>
                    <p class="text-sm text-secondary">
                      Click o arrastre para subir
                    </p>
                    <p class="text-xs text-secondary/70 mt-1">
                      JPG, PNG (máx. 2MB)
                    </p>
                  </div>
                </div>
              </div>
              <div class="space-y-2">
                <label
                  class="text-xs uppercase tracking-widest text-primary font-bold"
                  >Voucher de Pago <span class="text-secondary font-normal"
                    >(Opcional)</span
                  ></label
                >
                <div
                  class="border-2 border-dashed border-outline-variant rounded-lg p-4 text-center hover:border-primary transition-colors cursor-pointer"
                  id="voucher-dropzone"
                >
                  <input
                    class="hidden"
                    id="voucher-input"
                    name="voucher"
                    type="file"
                    accept="image/*,.pdf"
                  />
                  <div id="voucher-preview-container" class="hidden mb-3">
                    <img
                      id="voucher-preview"
                      class="max-h-32 object-contain rounded-lg mx-auto cursor-pointer hover:opacity-80 transition-opacity hidden"
                      alt="Preview"
                    />
                  </div>
                  <div id="voucher-placeholder">
                    <svg
                      class="w-8 h-8 mx-auto text-secondary mb-2"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                      ></path>
                    </svg>
                    <p class="text-sm text-secondary">Subir voucher</p>
                    <p class="text-xs text-secondary/70 mt-1">JPG, PNG o PDF</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="space-y-2">
              <label
                class="text-xs uppercase tracking-widest text-primary font-bold"
                >Requerimientos Especiales</label
              >
              <textarea
                class="w-full bg-transparent border-b border-outline-variant focus:border-primary focus:ring-0 text-on-surface py-2 outline-none transition-all"
                placeholder="Dietas, asistencia, etc."
                rows="2"
                name="special_requirements"></textarea>
            </div>
            <div class="pt-8">
              <button
                class="w-full bg-primary text-on-primary font-bold py-4 rounded-md shadow-xl hover:bg-tertiary transition-all active:scale-[0.98]"
                type="submit"
              >
                Confirmar Registro
              </button>
            </div>
          </form>
        </div>

        <div class="lg:col-span-1">
          <div
            class="bg-primary/10 border border-primary/30 rounded-xl p-6 sticky top-8"
          >
            <h3 class="font-headline text-2xl text-primary mb-4 text-center">
              Información de Pago
            </h3>
            <p class="text-sm text-secondary text-center mb-4">
              Escanee el código QR para realizar el pago de su inscripción.
            </p>
            <div class="flex justify-center mb-4">
              <img
                src="/images/qr-pago.jpeg"
                alt="Código QR para pago"
                id="qr-pago-img"
                class="w-64 h-64 object-contain rounded-lg bg-white p-2 shadow-lg cursor-pointer hover:opacity-80 transition-opacity"
              />
            </div>
            <div
              class="text-sm text-on-surface space-y-2 bg-surface/50 rounded-lg p-4"
            >
              <p class="font-bold text-primary">Datos para transferencia:</p>
              <p>
                <span class="text-secondary">Banco:</span> Banco Mercantil Santa Cruz
              </p>
              <p><span class="text-secondary">Cuenta:</span> 1004409716</p>
              <p>
                <span class="text-secondary">Nombre:</span> Patricia Pilar Gonzales
                Gemio
              </p>
              <p class="text-xs text-secondary mt-3">
                Una vez realizado el pago, suba su voucher en el formulario o
                envíelo por WhatsApp.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div
  id="voucher-modal"
  class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
>
  <button
    id="close-modal"
    class="absolute top-4 right-4 text-white hover:text-primary transition-colors"
    aria-label="Cerrar"
  >
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  <button
    id="download-voucher"
    class="absolute top-4 left-4 bg-primary text-on-primary px-4 py-2 rounded-lg flex items-center gap-2 hover:bg-tertiary transition-colors"
    aria-label="Descargar"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
      ></path>
    </svg>
    <span>Descargar</span>
  </button>
  <img
    id="voucher-modal-img"
    class="max-w-full max-h-[85vh] object-contain rounded-lg"
    alt="Imagen ampliada"
  />
</div>

<script>
  const deadline = new Date("2026-04-20").getTime();

  const updateCountdown = () => {
    const now = new Date().getTime();
    const distance = deadline - now;

    const daysEl = document.getElementById("days-remaining");
    const countdownEl = document.getElementById("registration-countdown");

    if (daysEl) {
      if (distance < 0) {
        daysEl.innerText = "0";
        if (countdownEl) {
          countdownEl.innerHTML = `
            <p class="text-lg text-on-surface">
              <span class="font-bold text-primary">El registro ha cerrado</span>
            </p>
            <p class="text-sm text-secondary mt-1">Gracias por su interés en la convención</p>
          `;
        }
      } else {
        const days = Math.ceil(distance / (1000 * 60 * 60 * 24));
        daysEl.innerText = days.toString();
      }
    }
  };

  updateCountdown();
  setInterval(updateCountdown, 60000);

  function setupDropzone(
    dropzoneId: string,
    inputId: string,
    previewId: string,
    previewContainerId: string,
    placeholderId: string,
  ) {
    const dropzone = document.getElementById(dropzoneId);
    const input = document.getElementById(inputId) as HTMLInputElement;
    const preview = document.getElementById(previewId) as HTMLImageElement;
    const previewContainer = document.getElementById(previewContainerId);
    const placeholder = document.getElementById(placeholderId);

    if (!dropzone || !input) return;

    dropzone.addEventListener("click", (e) => {
      if (
        e.target === preview &&
        preview.src &&
        !preview.src.includes("data:image/svg")
      ) {
        e.stopPropagation();
        const modal = document.getElementById("voucher-modal");
        const modalImg = document.getElementById(
          "voucher-modal-img",
        ) as HTMLImageElement;
        if (modal && modalImg) {
          modalImg.src = preview.src;
          modal.classList.remove("hidden");
          modal.classList.add("flex");
          document.body.style.overflow = "hidden";
        }
        return;
      }

      input.click();
    });

    dropzone.addEventListener("dragover", (e) => {
      e.preventDefault();
      dropzone.classList.add("border-primary", "bg-primary/5");
    });

    dropzone.addEventListener("dragleave", () => {
      dropzone.classList.remove("border-primary", "bg-primary/5");
    });

    dropzone.addEventListener("drop", (e) => {
      e.preventDefault();
      dropzone.classList.remove("border-primary", "bg-primary/5");
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        (input as HTMLInputElement).files = files;
        handleFile(files[0]);
      }
    });

    input.addEventListener("change", () => {
      if (input.files && input.files.length > 0) {
        handleFile(input.files[0]);
      }
    });

    function handleFile(file: File) {
      if (!file.type.startsWith("image/") && !file.type.includes("pdf")) return;

      if (file.type.startsWith("image/")) {
        const reader = new FileReader();
        reader.onload = (e) => {
          if (preview) {
            preview.src = e.target?.result as string;
            preview.classList.remove("hidden");
          }
          if (previewContainer) previewContainer.classList.remove("hidden");
          if (placeholder) placeholder.classList.add("hidden");
        };
        reader.readAsDataURL(file);
      } else {
        if (previewContainer) previewContainer.classList.remove("hidden");
        if (placeholder) placeholder.classList.add("hidden");
        if (preview) {
          preview.src =
            "data:image/svg+xml," +
            encodeURIComponent(
              '<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="%236b7280" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>',
            );
          preview.classList.remove("hidden");
        }
      }
    }
  }

  setupDropzone(
    "photo-dropzone",
    "photo-input",
    "photo-preview",
    "photo-preview-container",
    "photo-placeholder",
  );
  setupDropzone(
    "voucher-dropzone",
    "voucher-input",
    "voucher-preview",
    "voucher-preview-container",
    "voucher-placeholder",
  );

  const modal = document.getElementById("voucher-modal");
  const modalImg = document.getElementById(
    "voucher-modal-img",
  ) as HTMLImageElement;
  const closeBtn = document.getElementById("close-modal");
  const downloadBtn = document.getElementById("download-voucher");
  const qrImg = document.getElementById("qr-pago-img") as HTMLImageElement;

  let currentVoucherName = "voucher";

  if (modal && modalImg && closeBtn && downloadBtn) {
    closeBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    downloadBtn.addEventListener("click", () => {
      if (modalImg.src) {
        const link = document.createElement("a");
        link.href = modalImg.src;
        link.download = currentVoucherName;
        link.click();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        closeModal();
      }
    });

    function closeModal() {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    }
  }

  // QR image click-to-enlarge
  if (qrImg && modal && modalImg) {
    qrImg.addEventListener("click", () => {
      modalImg.src = qrImg.src;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    });
  }



  // === FORM SUBMISSION ===
  const registrationForm = document.getElementById("registration-form") as HTMLFormElement;

  if (registrationForm) {
    registrationForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = registrationForm.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (!submitBtn) return;

      // Show loading state
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = "Registrando...";
      submitBtn.classList.add("opacity-70", "cursor-wait");

      try {
        const formData = new FormData(registrationForm);

        // Add files from dropzone inputs (they might not be in the form natively)
        const photoInput = document.getElementById("photo-input") as HTMLInputElement;
        const voucherInput = document.getElementById("voucher-input") as HTMLInputElement;

        if (photoInput?.files?.[0]) {
          formData.set("photo", photoInput.files[0]);
        }
        if (voucherInput?.files?.[0]) {
          formData.set("voucher", voucherInput.files[0]);
        }

        const response = await fetch("/api/register", {
          method: "POST",
          body: formData,
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Show success message
          const formContainer = registrationForm.closest(".lg\\:col-span-2");
          if (formContainer) {
            formContainer.innerHTML = `
              <div class="text-center py-12 space-y-6">
                <div class="w-20 h-20 mx-auto bg-green-500/20 rounded-full flex items-center justify-center">
                  <svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <h3 class="font-headline text-3xl text-primary">¡Registro Exitoso!</h3>
                <p class="text-on-surface-variant text-lg">Su registro ha sido recibido correctamente.</p>
                <div class="bg-primary/10 border border-primary/30 rounded-lg p-6 inline-block">
                  <p class="text-sm text-secondary mb-1">Su código de registro es:</p>
                  <p class="text-3xl font-bold text-primary tracking-widest">${result.registration_code}</p>
                </div>
                <p class="text-sm text-secondary">Guarde este código, lo necesitará para recoger su credencial.</p>
              </div>
            `;
          }
        } else {
          // Show error
          showFormError(result.error || "Error al procesar el registro.");
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          submitBtn.classList.remove("opacity-70", "cursor-wait");
        }
      } catch (err) {
        showFormError("Error de conexión. Verifique su internet e inténtelo de nuevo.");
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        submitBtn.classList.remove("opacity-70", "cursor-wait");
      }
    });
  }

  function showFormError(message: string) {
    // Remove existing error if any
    const existing = document.getElementById("form-error-msg");
    if (existing) existing.remove();

    const errorDiv = document.createElement("div");
    errorDiv.id = "form-error-msg";
    errorDiv.className = "bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg p-4 text-center text-sm mt-4";
    errorDiv.textContent = message;

    const form = document.getElementById("registration-form");
    if (form) {
      form.insertBefore(errorDiv, form.firstChild);
      errorDiv.scrollIntoView({ behavior: "smooth", block: "center" });

      // Auto-remove after 8 seconds
      setTimeout(() => errorDiv.remove(), 8000);
    }
  }
</script>
