---
---

<section class="py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="font-headline text-4xl text-on-surface mb-4">Gastronomía Orureña</h2>
      <div class="flex flex-wrap justify-center gap-2">
        <button class="px-4 py-1 text-xs font-bold uppercase tracking-widest bg-primary text-on-primary rounded-full">Típico Boliviano</button>
        <button class="px-4 py-1 text-xs font-bold uppercase tracking-widest bg-surface-container-high text-secondary rounded-full hover:bg-surface-container-highest transition-colors">Internacional</button>
        <button class="px-4 py-1 text-xs font-bold uppercase tracking-widest bg-surface-container-high text-secondary rounded-full hover:bg-surface-container-highest transition-colors">Café &amp; Postres</button>
      </div>
    </div>
    <div class="grid md:grid-cols-4 gap-6">
      <div class="bg-surface p-6 rounded-lg">
        <div class="flex justify-between items-start mb-4">
          <h4 class="font-bold">El Rostro Asado</h4>
          <span class="text-primary flex"><span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>5</span>
        </div>
        <p class="text-xs text-secondary mb-2">Comida Típica</p>
        <p class="text-sm text-on-surface-variant mb-4">Calle Bolivar esq. Potosí</p>
        <p class="text-xs italic opacity-60">Abierto 18:00 - 02:00</p>
      </div>
      <div class="bg-surface p-6 rounded-lg">
        <div class="flex justify-between items-start mb-4">
          <h4 class="font-bold">Nayra Café</h4>
          <span class="text-primary flex"><span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>4.8</span>
        </div>
        <p class="text-xs text-secondary mb-2">Cafetería</p>
        <p class="text-sm text-on-surface-variant mb-4">Plaza 10 de Febrero</p>
        <p class="text-xs italic opacity-60">Abierto 08:00 - 22:00</p>
      </div>
      <div class="bg-surface p-6 rounded-lg">
        <div class="flex justify-between items-start mb-4">
          <h4 class="font-bold">Sucre III</h4>
          <span class="text-primary flex"><span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>4.5</span>
        </div>
        <p class="text-xs text-secondary mb-2">Carnes &amp; Grill</p>
        <p class="text-sm text-on-surface-variant mb-4">Calle Sucre #542</p>
        <p class="text-xs italic opacity-60">Abierto 11:30 - 23:00</p>
      </div>
      <div class="bg-surface p-6 rounded-lg">
        <div class="flex justify-between items-start mb-4">
          <h4 class="font-bold">Pastelería Alemana</h4>
          <span class="text-primary flex"><span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">star</span>4.7</span>
        </div>
        <p class="text-xs text-secondary mb-2">Postres</p>
        <p class="text-sm text-on-surface-variant mb-4">Calle Pagador</p>
        <p class="text-xs italic opacity-60">Abierto 09:00 - 21:00</p>
      </div>
    </div>
  </div>
</section>
