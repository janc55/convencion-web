---
---

<section class="py-24 bg-surface-container-low" id="programa">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="font-headline text-4xl text-center text-on-surface mb-12">Agenda de Actividades</h2>
    
    <div class="flex justify-center gap-4 mb-12">
      <button class="px-6 py-2 bg-primary text-on-primary font-bold rounded-md">Día 1</button>
      <button class="px-6 py-2 bg-surface-container-high text-secondary font-bold rounded-md hover:text-primary transition-colors">Día 2</button>
      <button class="px-6 py-2 bg-surface-container-high text-secondary font-bold rounded-md hover:text-primary transition-colors">Día 3</button>
    </div>

    <div class="relative pl-8 border-l-2 border-primary/30 space-y-12">
      <!-- Event 1 -->
      <div class="relative">
        <div class="absolute -left-[41px] top-0 w-5 h-5 bg-primary rounded-full border-4 border-surface shadow-[0_0_10px_rgba(238,194,0,0.5)]"></div>
        <div class="bg-surface-container-high p-6 rounded-xl hover:translate-x-2 transition-transform duration-300">
          <div class="flex justify-between items-start mb-4">
            <span class="text-primary font-bold tracking-tighter text-xl">08:00 AM</span>
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">how_to_reg</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Registro de Delegados</h3>
          <p class="text-on-surface-variant mb-4">Recepción y entrega de credenciales en el Hall Principal.</p>
          <div class="flex items-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">location_on</span> Lobby Principal</span>
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">person</span> Comité Organizador</span>
          </div>
        </div>
      </div>

      <!-- Event 2 -->
      <div class="relative">
        <div class="absolute -left-[41px] top-0 w-5 h-5 bg-primary rounded-full border-4 border-surface"></div>
        <div class="bg-surface-container-high p-6 rounded-xl hover:translate-x-2 transition-transform duration-300">
          <div class="flex justify-between items-start mb-4">
            <span class="text-primary font-bold tracking-tighter text-xl">10:30 AM</span>
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">stars</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Ceremonia de Apertura</h3>
          <p class="text-on-surface-variant mb-4">Inauguración oficial con presencia de autoridades distritales e internacionales.</p>
          <div class="flex items-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">location_on</span> Auditorio Magno</span>
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">person</span> Gobernador de Distrito</span>
          </div>
        </div>
      </div>

      <!-- Event 3 -->
      <div class="relative">
        <div class="absolute -left-[41px] top-0 w-5 h-5 bg-primary rounded-full border-4 border-surface"></div>
        <div class="bg-surface-container-high p-6 rounded-xl hover:translate-x-2 transition-transform duration-300">
          <div class="flex justify-between items-start mb-4">
            <span class="text-primary font-bold tracking-tighter text-xl">08:00 PM</span>
            <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">nightlife</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Cena de Gala Folklórica</h3>
          <p class="text-on-surface-variant mb-4">Noche de confraternización con demostración de danzas tradicionales de Oruro.</p>
          <div class="flex items-center gap-4 text-sm text-secondary">
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">location_on</span> Salon Imperial</span>
            <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">person</span> Conjunto Tradicional</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
