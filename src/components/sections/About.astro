<section class="py-24 bg-surface">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <div class="order-2 md:order-1">
      <div class="inline-flex gap-4 mb-6">
        <span class="bg-surface-container-high text-primary px-3 py-1 text-xs font-bold rounded-full uppercase tracking-widest border border-primary/10">75 años de servicio</span>
        <span class="bg-surface-container-high text-primary px-3 py-1 text-xs font-bold rounded-full uppercase tracking-widest border border-primary/10">Tradición Lions</span>
      </div>
      <h2 class="font-headline text-4xl md:text-5xl text-on-surface mb-8">Bienvenidos a la Capital del Folklore</h2>
      <p class="text-on-surface-variant text-lg leading-relaxed mb-10">
          Nos reunimos en el corazón de Bolivia para celebrar siete décadas y media de compromiso social. La ciudad de Oruro abre sus puertas a los distritos B-1 y B-2 en un encuentro que fusiona la mística de nuestras tradiciones con la fuerza de nuestro servicio.
      </p>
      <div class="space-y-6">
        <div class="flex items-start gap-4 p-4 bg-surface-container-low rounded-xl">
          <span class="material-symbols-outlined text-primary text-3xl">calendar_today</span>
          <div>
            <h4 class="font-bold text-on-surface">Fecha del Evento</h4>
            <p class="text-on-surface-variant">Mayo 15 - 18, 2025</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 bg-surface-container-low rounded-xl">
          <span class="material-symbols-outlined text-primary text-3xl">map</span>
          <div>
            <h4 class="font-bold text-on-surface">Sede Principal</h4>
            <p class="text-on-surface-variant">Centro de Convenciones Oruro</p>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 bg-surface-container-low rounded-xl">
          <span class="material-symbols-outlined text-primary text-3xl">groups</span>
          <div>
            <h4 class="font-bold text-on-surface">Convocatoria</h4>
            <p class="text-on-surface-variant">Distritos B-1 y B-2 Nacional</p>
          </div>
        </div>
      </div>
    </div>
    <div class="order-1 md:order-2 relative">
      <img class="rounded-2xl shadow-2xl relative z-10" alt="Arquitectura colonial y moderna de la ciudad de Oruro" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA5h9YX_4S0wA_DehsGGPMIOcX8XqxO5zuRYBMEVHMfLM3uyPTp_Jm9XMXZBHF96Tg8wFHt40VC8mIgolA5q5-DHnFqj_4vCY3XLp51kvcmzfj_7sss1hKcc2zMPz-JuUq1KWkEOlqR1FZ0qxYKr5mXbNGARauk0SoZoFvxEwOSYZkraINPKfs53SRYSw7TNKErrnRbpyteBKbzuh_6riYB9ZBmTW4rsqgOsjeVvjL48vQv5s_4c6UMgxTqh5SWjtiX8dTCjTtw8Uo" />
      <div class="absolute -top-6 -right-6 w-full h-full border-2 border-primary/20 rounded-2xl -z-0"></div>
    </div>
  </div>
</section>
