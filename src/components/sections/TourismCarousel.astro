---

---

<section class="py-24 bg-surface overflow-hidden" id="turismo">
  <div class="max-w-7xl mx-auto px-6 mb-12">
    <h2 class="font-headline text-4xl text-on-surface">Explora Oruro</h2>
  </div>
  <div class="flex gap-6 overflow-x-auto pb-8 px-6 scrollbar-hide no-scrollbar">
    <!-- Item 1 -->
    <div
      class="relative flex-none w-[350px] h-[500px] rounded-2xl overflow-hidden group"
    >
      <img
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
        alt="Santuario del Socavón en Oruro"
        src="/images/santuario.jpg"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface-container-highest via-transparent to-transparent"
      >
      </div>
      <div class="absolute bottom-0 p-8">
        <h3 class="font-headline text-3xl text-primary mb-2">
          Santuario del Socavón
        </h3>
        <p
          class="text-sm text-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
          Epicentro de la fe orureña y lugar de entrada a la mina.
        </p>
      </div>
    </div>
    <!-- Item 2 -->
    <div
      class="relative flex-none w-[350px] h-[500px] rounded-2xl overflow-hidden group"
    >
      <img
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
        alt="Carnaval de Oruro Patrimonio UNESCO"
        src="images/carnaval.jpg"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface-container-highest via-transparent to-transparent"
      >
      </div>
      <div class="absolute bottom-0 p-8">
        <h3 class="font-headline text-3xl text-primary mb-2">
          Carnaval de Oruro
        </h3>
        <p
          class="text-sm text-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
          Obra Maestra del Patrimonio Oral e Intangible de la Humanidad.
        </p>
      </div>
    </div>
    <!-- Item 3 -->
    <div
      class="relative flex-none w-[350px] h-[500px] rounded-2xl overflow-hidden group"
    >
      <img
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
        alt="Lago Uru Uru al atardecer"
        src="/images/arenales.jpg"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface-container-highest via-transparent to-transparent"
      >
      </div>
      <div class="absolute bottom-0 p-8">
        <h3 class="font-headline text-3xl text-primary mb-2">Lago Uru Uru</h3>
        <p
          class="text-sm text-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
          Naturaleza impresionante a las afueras de la ciudad.
        </p>
      </div>
    </div>
    <!-- Item 4 -->
    <div
      class="relative flex-none w-[350px] h-[500px] rounded-2xl overflow-hidden group"
    >
      <img
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
        alt="Mina San José entrada histórica"
        src="/images/mina.jpg"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface-container-highest via-transparent to-transparent"
      >
      </div>
      <div class="absolute bottom-0 p-8">
        <h3 class="font-headline text-3xl text-primary mb-2">Mina San José</h3>
        <p
          class="text-sm text-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
          Historia viva de la minería boliviana.
        </p>
      </div>
    </div>
  </div>
</section>
