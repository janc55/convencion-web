---

---

<section
  class="relative min-h-screen flex items-center justify-center pt-20 pb-10 overflow-hidden bg-hero-gradient"
  id="hero"
>
  <div class="absolute inset-0 hex-pattern opacity-30"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
    <div class="mb-8 flex justify-center gap-4 items-center hero-scale-in">
      <img
        class="w-32 h-32 object-contain drop-shadow-[0_0_20px_rgba(238,194,0,0.3)] hero-glow"
        alt="Escudo del Club de Leones y la Virgen del Socavón"
        src="/images/logo-convencion.jpeg"
      />
    </div>
    <h1
      class="font-headline text-5xl md:text-8xl text-primary leading-tight mb-4 tracking-tighter hero-slide-down anim-delay-200"
    >
      LXXV Convención Nacional
    </h1>
    <h2
      class="font-headline text-3xl md:text-5xl text-primary leading-tight mb-2 tracking-tight hero-fade-in anim-delay-400"
    >
      LIII Bidistrital
    </h2>
    <p
      class="text-xl md:text-3xl text-white mb-4 font-light hero-fade-in anim-delay-450"
    >
      L. Luis Cabrera Francisdakis
    </p>
    <p
      class="text-xl md:text-2xl text-primary font-semibold mb-2 hero-fade-in anim-delay-450"
    >
      Del <span class="font-bold">30</span> de abril al <span class="font-bold"
        >3</span
      > de mayo
    </p>
    <div
      class="flex items-center justify-center gap-2 text-on-surface-variant mb-12 hero-fade-in anim-delay-500"
    >
      <span class="material-symbols-outlined text-primary">location_on</span>
      <span class="uppercase tracking-widest text-sm"
        >Oruro, Bolivia · 2026</span
      >
    </div>
    <div
      class="grid grid-cols-4 gap-2 md:gap-4 max-w-2xl mx-auto mb-12 px-2 md:px-0"
    >
      <div
        class="bg-surface-container-low p-2 md:p-4 rounded-lg border border-primary/20 hero-scale-in anim-delay-600"
      >
        <span
          id="countdown-days"
          class="block text-2xl md:text-3xl font-bold text-primary">00</span
        >
        <span
          class="text-[10px] md:text-xs uppercase md:tracking-widest opacity-70"
          >Días</span
        >
      </div>
      <div
        class="bg-surface-container-low p-2 md:p-4 rounded-lg border border-primary/20 hero-scale-in anim-delay-700"
      >
        <span
          id="countdown-hours"
          class="block text-2xl md:text-3xl font-bold text-primary">00</span
        >
        <span
          class="text-[10px] md:text-xs uppercase md:tracking-widest opacity-70"
          >Horas</span
        >
      </div>
      <div
        class="bg-surface-container-low p-2 md:p-4 rounded-lg border border-primary/20 hero-scale-in anim-delay-800"
      >
        <span
          id="countdown-minutes"
          class="block text-2xl md:text-3xl font-bold text-primary">00</span
        >
        <span
          class="text-[10px] md:text-xs uppercase md:tracking-widest opacity-70"
          >Min</span
        >
      </div>
      <div
        class="bg-surface-container-low p-2 md:p-4 rounded-lg border border-primary/20 hero-scale-in anim-delay-900"
      >
        <span
          id="countdown-seconds"
          class="block text-2xl md:text-3xl font-bold text-primary">00</span
        >
        <span
          class="text-[10px] md:text-xs uppercase md:tracking-widest opacity-70"
          >Seg</span
        >
      </div>
    </div>
    <a
      class="inline-block bg-primary text-on-primary px-10 py-4 rounded-md font-bold text-lg hover:bg-tertiary transition-all hover:scale-105 active:scale-95 shadow-xl hero-pulse anim-delay-1100"
      href="#registro"
    >
      Registrarse Ahora
    </a>
  </div>
</section>

<script>
  // Target date: 30 de Abril, 2026
  const targetDate = new Date("2026-04-30T00:00:00").getTime();

  const updateCountdown = () => {
    const now = new Date().getTime();
    const distance = targetDate - now;

    if (distance < 0) {
      return; // Event has started
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor(
      (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
    );
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    const formatNumber = (num: number) => num.toString().padStart(2, "0");

    const daysEl = document.getElementById("countdown-days");
    const hoursEl = document.getElementById("countdown-hours");
    const minutesEl = document.getElementById("countdown-minutes");
    const secondsEl = document.getElementById("countdown-seconds");

    if (daysEl && hoursEl && minutesEl && secondsEl) {
      daysEl.innerText = formatNumber(days);
      hoursEl.innerText = formatNumber(hours);
      minutesEl.innerText = formatNumber(minutes);
      secondsEl.innerText = formatNumber(seconds);
    }
  };

  setInterval(updateCountdown, 1000);
  updateCountdown(); // Initialize immediately
</script>
