<section class="py-24 bg-surface" id="hoteles">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="font-headline text-4xl text-on-surface mb-2">Hospedaje</h2>
        <p class="text-on-surface-variant">Opciones recomendadas con tarifas especiales para convencionistas.</p>
      </div>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Hotel 1 -->
      <div class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all">
        <div class="h-56 overflow-hidden">
          <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Fachada elegante del Hotel Terminal Oruro" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBQ6O1Vi3ELOhDpIPNku1Q1688SyX1MaQauvBCniEjGwa32RbBKdxa0YwF-dTFxhfFc12L3PF2QlKzyRQHdK1i9iymXY6KGMb7aO8BXRMfVgMTqxgLZsDR08O73Phkk5kFW8NB_VOkAb57vOXDzv3eLJC2ela38OUbf4W1zDg-0dVTdwSI5BYZr96EDp_mNN0D9xnnPUYnzn30jTvPKHz3vrdvXYhnxoS55Chgiu-5HBrMxJtLVurRD3k-mH72BKybNvdPxSTa_neU" />
        </div>
        <div class="p-6">
          <div class="flex text-primary mb-2">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Hotel Terminal</h3>
          <p class="text-on-surface-variant text-sm mb-4">Cerca del centro histórico y la sede.</p>
          <div class="flex justify-between items-center pt-4 border-t border-white/5">
            <span class="text-primary font-bold">$45 <small class="text-secondary font-normal">/ noche</small></span>
            <button class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors">Reservar</button>
          </div>
        </div>
      </div>

      <!-- Hotel 2 -->
      <div class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all">
        <div class="h-56 overflow-hidden">
          <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Interiores de lujo del Gran Hotel Oruro" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAvJQDEqXbCUdcVDOezSe2qefvr_ImjPDmpT_y_Ta67bv43yTywqxt73EJmF9-PWbRYY9wE2zOB9BqL8h_61yVfyLJ8funDyfLotiJtT2KgKhZEVeSFSE3Vr2IPVldB7MDiALwxvaZjxjdFPDiiwlajlCrwdPPGz_HhTsLxHBPQ-U9kCEuIVDbCaqns0FAE-kWgIHpXk5PGZosFYzYAA1_AewyKdwssSVD8KPyqJDBAGSj6U2FDjdkK_9mRBa0otkPzoWkWPUSdneE" />
        </div>
        <div class="p-6">
          <div class="flex text-primary mb-2">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Gran Hotel Oruro</h3>
          <p class="text-on-surface-variant text-sm mb-4">Excelencia y confort en el corazón de la ciudad.</p>
          <div class="flex justify-between items-center pt-4 border-t border-white/5">
            <span class="text-primary font-bold">$75 <small class="text-secondary font-normal">/ noche</small></span>
            <button class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors">Reservar</button>
          </div>
        </div>
      </div>

      <!-- Hotel 3 -->
      <div class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all">
        <div class="h-56 overflow-hidden">
          <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Hotel Eden Oruro con vistas panorámicas" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZV6NlGENf10fX1LqLkZP-OHzEzPCCY-8rTyz5FA0t52VP6x4G46GOBVZyPZeiUapxiMWu654vBDWceRvEAXMfPe6sVWxUvkx3K0xXcKT60jB9KXwgq8U6sR5mB_mz4pKMRtOWUyJ9Oge_t4Yv4qOdrl3M_nhykyIXdUQ92580Zl6xlXdGYgz82XYs5igIW5WwYgGQipCvZkkxpRNFTkePx41n6CMW7CT0u5oxodJprP_n18KejGtzN7TwPzWUP--Pw03dENktiso" />
        </div>
        <div class="p-6">
          <div class="flex text-primary mb-2">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Hotel Eden</h3>
          <p class="text-on-surface-variant text-sm mb-4">Vistas panorámicas y servicios de spa.</p>
          <div class="flex justify-between items-center pt-4 border-t border-white/5">
            <span class="text-primary font-bold">$60 <small class="text-secondary font-normal">/ noche</small></span>
            <button class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors">Reservar</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
