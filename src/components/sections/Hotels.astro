---

---

<section class="py-24 bg-surface" id="hoteles">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-end mb-12 animate-on-scroll">
      <div>
        <h2 class="font-headline text-4xl text-on-surface mb-2">Hospedaje</h2>
        <p class="text-on-surface-variant">
          Opciones recomendadas con tarifas especiales para convencionistas.
        </p>
      </div>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Hotel 1 -->
      <div
        class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all animate-on-scroll scale-up stagger-1"
      >
        <div class="h-56 overflow-hidden">
          <img
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            alt="Fachada elegante del Hotel Terminal Oruro"
            src="/images/claymor.jpg"
          />
        </div>
        <div class="p-6">
          <div class="flex text-primary mb-2">
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
          </div>
          <h3 class="text-xl font-bold mb-2">Hotel Claymor</h3>
          <p class="text-on-surface-variant text-sm mb-4">
            Cerca del centro histórico y la sede.
          </p>
          <div
            class="flex justify-between items-center pt-4 border-t border-white/5"
          >
            <span class="text-primary font-bold"
              >$45 <small class="text-secondary font-normal">/ noche</small
              ></span
            >
            <button
              class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors"
              >Reservar</button
            >
          </div>
        </div>
      </div>

      <!-- Hotel 2 -->
      <div
        class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all animate-on-scroll scale-up stagger-2"
      >
        <div class="h-56 overflow-hidden">
          <img
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            alt="Interiores de lujo del Gran Hotel Oruro"
            src="/images/sucre.jpg"
          />
        </div>
        <div class="p-6">
          <div class="flex text-primary mb-2">
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
          </div>
          <h3 class="text-xl font-bold mb-2">Gran Hotel Sucre</h3>
          <p class="text-on-surface-variant text-sm mb-4">
            Excelencia y confort en el corazón de la ciudad.
          </p>
          <div
            class="flex justify-between items-center pt-4 border-t border-white/5"
          >
            <span class="text-primary font-bold"
              >$75 <small class="text-secondary font-normal">/ noche</small
              ></span
            >
            <button
              class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors"
              >Reservar</button
            >
          </div>
        </div>
      </div>

      <!-- Hotel 3 -->
      <div
        class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all animate-on-scroll scale-up stagger-3"
      >
        <div class="h-56 overflow-hidden">
          <img
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            alt="Hotel Eden Oruro con vistas panorámicas"
            src="/images/eden.jpg"
          />
        </div>
        <div class="p-6">
          <div class="flex text-primary mb-2">
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
            <span
              class="material-symbols-outlined text-sm"
              style="font-variation-settings: 'FILL' 1;">star</span
            >
          </div>
          <h3 class="text-xl font-bold mb-2">Hotel Eden</h3>
          <p class="text-on-surface-variant text-sm mb-4">
            Vistas panorámicas y servicios de spa.
          </p>
          <div
            class="flex justify-between items-center pt-4 border-t border-white/5"
          >
            <span class="text-primary font-bold"
              >$60 <small class="text-secondary font-normal">/ noche</small
              ></span
            >
            <button
              class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors"
              >Reservar</button
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
