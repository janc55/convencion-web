---
import { hotelsData } from "../../data/hotels";

const featuredHotels = hotelsData.slice(0, 3);
---

<section class="py-24 bg-surface" id="hoteles">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex justify-between items-end mb-12 animate-on-scroll">
      <div>
        <h2 class="font-headline text-4xl text-on-surface mb-2">Hospedaje</h2>
        <p class="text-on-surface-variant">
          Opciones recomendadas con tarifas especiales para convencionistas.
        </p>
        <p class="text-on-surface-variant">
          Precios referenciales sujetos a disponibilidad.
        </p>
      </div>
      <a
        href="/hoteles"
        class="hidden md:inline-flex items-center gap-2 px-6 py-3 bg-surface-container-high text-secondary font-bold rounded-md hover:text-primary hover:bg-surface-container-low transition-all"
      >
        Ver todos
        <span class="material-symbols-outlined text-xl">arrow_forward</span>
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {
        featuredHotels.map((hotel, index) => (
          <div
            class="group bg-surface-container-low rounded-xl overflow-hidden border border-white/5 hover:border-primary/30 transition-all animate-on-scroll scale-up"
            style={`stagger-${index + 1}`}
          >
            <div class="h-56 overflow-hidden">
              <img
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                alt={`${hotel.name} en Oruro`}
                src={hotel.image || "/images/hotel-placeholder.jpg"}
              />
            </div>
            <div class="p-6">
              <div class="flex text-primary mb-2">
                {[...Array(hotel.stars)].map(() => (
                  <span
                    class="material-symbols-outlined text-sm"
                    style="font-variation-settings: 'FILL' 1;"
                  >
                    star
                  </span>
                ))}
              </div>
              <h3 class="text-xl font-bold mb-2">{hotel.name}</h3>
              <p class="text-on-surface-variant text-sm mb-4">
                {hotel.description}
              </p>
              <div class="flex justify-between items-center pt-4 border-t border-white/5">
                <span class="text-primary font-bold">
                  {hotel.currency === "USD" ? "$" : ""}
                  {hotel.price}
                  {hotel.currency === "Bs." ? " Bs." : ""}{" "}
                  <small class="text-secondary font-normal">/ noche</small>
                </span>
                {hotel.bookingUrl ? (
                  <a
                    href={hotel.bookingUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-bold uppercase tracking-widest text-secondary hover:text-primary transition-colors"
                  >
                    Reservar
                  </a>
                ) : (
                  <button class="text-sm font-bold uppercase tracking-widest text-secondary cursor-not-allowed opacity-50">
                    Reservar
                  </button>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <div class="mt-8 text-center md:hidden">
      <a
        href="/hoteles"
        class="inline-flex items-center gap-2 px-6 py-3 bg-surface-container-high text-secondary font-bold rounded-md hover:text-primary hover:bg-surface-container-low transition-all"
      >
        Ver todos los hoteles
        <span class="material-symbols-outlined text-xl">arrow_forward</span>
      </a>
    </div>
  </div>
</section>
